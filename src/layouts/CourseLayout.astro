---
import BaseLayout from './BaseLayout.astro';
import ProgressTracker from '@/components/ProgressTracker.astro';

interface Props {
  title: string;
  description?: string;
  category: string;
  difficulty?: 'beginner' | 'intermediate' | 'advanced';
  duration?: string;
  lastUpdated?: Date;
  editUrl?: string;
}

const { title, description, category, difficulty, duration, lastUpdated, editUrl } = Astro.props;
const basePath = import.meta.env.BASE_URL;

// Derive course ID from URL: e.g. /LTM-GH-Session/workshops/code-completion/ → workshops/code-completion
const urlPath = Astro.url.pathname.replace(basePath, '').replace(/\/$/, '');
const courseId = urlPath;

const difficultyColors = {
  beginner: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
  intermediate: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',
  advanced: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
};
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-surface-500 dark:text-surface-400">
      <a href={basePath} class="hover:text-primary-600 dark:hover:text-primary-400">Home</a>
      <span class="mx-2">›</span>
      <a href={`${basePath}${category}`} class="capitalize hover:text-primary-600 dark:hover:text-primary-400">{category}</a>
      <span class="mx-2">›</span>
      <span class="text-surface-700 dark:text-surface-200">{title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-3xl font-extrabold tracking-tight text-surface-900 dark:text-white sm:text-4xl">
        {title}
      </h1>
      {description && (
        <p class="mt-3 text-lg text-surface-600 dark:text-surface-300">{description}</p>
      )}
      <div class="mt-4 flex flex-wrap items-center gap-3">
        {difficulty && (
          <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${difficultyColors[difficulty]}`}>
            {difficulty.charAt(0).toUpperCase() + difficulty.slice(1)}
          </span>
        )}
        {duration && (
          <span class="inline-flex items-center gap-1 text-sm text-surface-500 dark:text-surface-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {duration}
          </span>
        )}
        {lastUpdated && (
          <span class="text-sm text-surface-500 dark:text-surface-400">
            Updated {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </span>
        )}
      </div>
    </header>

    <!-- Content -->
    <article class="prose dark:prose-invert" data-pagefind-body>
      <slot />
    </article>

    <!-- Progress Tracker -->
    <ProgressTracker courseId={courseId} />

    <!-- Footer actions -->
    <div class="mt-12 flex items-center justify-between border-t border-surface-200 pt-6 dark:border-surface-800">
      {editUrl && (
        <a href={editUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm text-surface-500 hover:text-primary-600 dark:text-surface-400 dark:hover:text-primary-400">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Edit on GitHub
        </a>
      )}
    </div>
  </div>
</BaseLayout>
