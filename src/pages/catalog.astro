---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CourseCard from '@/components/CourseCard.astro';
import { getCollection } from 'astro:content';

const [workshops, paths, technologies, agentic] = await Promise.all([
  getCollection('workshops'),
  getCollection('paths'),
  getCollection('technologies'),
  getCollection('agentic'),
]);

const basePath = import.meta.env.BASE_URL.replace(/\/?$/, '/');

type CourseItem = {
  title: string;
  description: string;
  href: string;
  icon?: string;
  difficulty: 'beginner' | 'intermediate' | 'advanced';
  duration: string;
  tags: string[];
  category: string;
};

const allCourses: CourseItem[] = [
  ...workshops.map(w => ({
    title: w.data.title,
    description: w.data.description,
    href: `${basePath}workshops/${w.id.replace(/\.md$/, '')}`,
    icon: w.data.icon,
    difficulty: w.data.difficulty,
    duration: w.data.duration,
    tags: [...w.data.tags, 'workshop'],
    category: 'workshops',
  })),
  ...paths.map(p => ({
    title: p.data.title,
    description: p.data.description,
    href: `${basePath}paths/${p.id.replace(/\.md$/, '')}`,
    icon: p.data.icon,
    difficulty: p.data.difficulty,
    duration: p.data.duration,
    tags: [p.data.persona, 'learning-path'],
    category: 'paths',
  })),
  ...technologies.map(t => ({
    title: t.data.title,
    description: t.data.description,
    href: `${basePath}technologies/${t.id.replace(/\.md$/, '')}`,
    icon: t.data.icon,
    difficulty: t.data.difficulty,
    duration: t.data.duration,
    tags: [...t.data.tags, 'technology'],
    category: 'technologies',
  })),
  ...agentic.map(a => ({
    title: a.data.title,
    description: a.data.description,
    href: `${basePath}agentic/${a.id.replace(/\.md$/, '')}`,
    icon: a.data.icon,
    difficulty: a.data.difficulty,
    duration: a.data.duration,
    tags: [...a.data.tags, 'agentic'],
    category: 'agentic',
  })),
];
---

<BaseLayout title="Course Catalog" description="Browse all available courses, workshops, and learning paths">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h1 class="text-3xl font-extrabold text-surface-900 dark:text-white sm:text-4xl">
        📚 Course Catalog
      </h1>
      <p class="mt-3 text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto">
        Browse all available courses across workshops, learning paths, technologies, and agentic development.
      </p>
    </div>

    <!-- Filters -->
    <div class="mb-8 flex flex-wrap items-center justify-center gap-2" id="filters">
      <button data-filter="all" class="filter-btn active rounded-full bg-primary-600 px-4 py-1.5 text-sm font-medium text-white transition-colors">All</button>
      <button data-filter="workshops" class="filter-btn rounded-full bg-surface-100 px-4 py-1.5 text-sm font-medium text-surface-700 hover:bg-surface-200 dark:bg-surface-800 dark:text-surface-300 dark:hover:bg-surface-700 transition-colors">Workshops</button>
      <button data-filter="paths" class="filter-btn rounded-full bg-surface-100 px-4 py-1.5 text-sm font-medium text-surface-700 hover:bg-surface-200 dark:bg-surface-800 dark:text-surface-300 dark:hover:bg-surface-700 transition-colors">Learning Paths</button>
      <button data-filter="technologies" class="filter-btn rounded-full bg-surface-100 px-4 py-1.5 text-sm font-medium text-surface-700 hover:bg-surface-200 dark:bg-surface-800 dark:text-surface-300 dark:hover:bg-surface-700 transition-colors">Technologies</button>
      <button data-filter="agentic" class="filter-btn rounded-full bg-surface-100 px-4 py-1.5 text-sm font-medium text-surface-700 hover:bg-surface-200 dark:bg-surface-800 dark:text-surface-300 dark:hover:bg-surface-700 transition-colors">Agentic Dev</button>
    </div>

    {allCourses.length === 0 ? (
      <div class="text-center py-16 text-surface-500 dark:text-surface-400">
        <p class="text-lg">Courses are being prepared! 🚧</p>
        <p class="mt-2 text-sm">Check back shortly — new content is being generated.</p>
      </div>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="course-grid">
        {allCourses.map((course) => (
          <div data-category={course.category} class="course-item">
            <CourseCard
              title={course.title}
              description={course.description}
              href={course.href}
              icon={course.icon}
              difficulty={course.difficulty}
              duration={course.duration}
              tags={course.tags}
            />
          </div>
        ))}
      </div>
    )}
  </div>

  <script>
    function setupFilters() {
      const buttons = document.querySelectorAll('.filter-btn');
      const items = document.querySelectorAll('.course-item');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = btn.getAttribute('data-filter');

          buttons.forEach(b => {
            b.classList.remove('active', 'bg-primary-600', 'text-white');
            b.classList.add('bg-surface-100', 'text-surface-700', 'dark:bg-surface-800', 'dark:text-surface-300');
          });
          btn.classList.add('active', 'bg-primary-600', 'text-white');
          btn.classList.remove('bg-surface-100', 'text-surface-700', 'dark:bg-surface-800', 'dark:text-surface-300');

          items.forEach(item => {
            const el = item as HTMLElement;
            if (filter === 'all' || el.getAttribute('data-category') === filter) {
              el.style.display = '';
            } else {
              el.style.display = 'none';
            }
          });
        });
      });
    }

    setupFilters();
    document.addEventListener('astro:after-swap', setupFilters);
  </script>
</BaseLayout>
