---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CourseCard from '@/components/CourseCard.astro';
import { getCollection } from 'astro:content';

const paths = (await getCollection('paths')).sort((a, b) => a.data.order - b.data.order);
const basePath = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title="Learning Paths" description="Curated learning journeys tailored to your role">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h1 class="text-3xl font-extrabold text-surface-900 dark:text-white sm:text-4xl">
        🗺️ Learning Paths
      </h1>
      <p class="mt-3 text-lg text-surface-600 dark:text-surface-400 max-w-2xl mx-auto">
        Curated learning journeys tailored to your role. Follow a path designed for your persona and experience level.
      </p>
    </div>

    {paths.length === 0 ? (
      <div class="text-center py-16 text-surface-500 dark:text-surface-400">
        <p class="text-lg">Learning paths coming soon! 🚧</p>
        <p class="mt-2 text-sm">Check back shortly — new content is being generated.</p>
      </div>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {paths.map((path) => (
          <CourseCard
            title={path.data.title}
            description={path.data.description}
            href={`${basePath}paths/${path.id.replace(/\.md$/, '')}`}
            icon={path.data.icon}
            difficulty={path.data.difficulty}
            duration={path.data.duration}
            tags={[path.data.persona]}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
