---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
  difficulty?: 'beginner' | 'intermediate' | 'advanced';
  duration?: string;
  tags?: string[];
}

const { title, description, href, icon, difficulty, duration, tags = [] } = Astro.props;

const difficultyColors = {
  beginner: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
  intermediate: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',
  advanced: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
};

// Derive course ID from href: e.g. /LTM-GH-Session/workshops/code-completion → workshops/code-completion
const basePath = import.meta.env.BASE_URL;
const courseId = href.replace(basePath, '').replace(/\/$/, '');
---

<a href={href} class="group relative block rounded-xl border border-surface-200 bg-white p-6 shadow-sm transition-all hover:border-primary-300 hover:shadow-md dark:border-surface-700 dark:bg-surface-900 dark:hover:border-primary-600" data-course-id={courseId}>
  <!-- Completion badge (hidden by default, shown via JS) -->
  <span
    class="course-complete-badge absolute -right-2 -top-2 hidden h-6 w-6 items-center justify-center rounded-full bg-green-500 text-white shadow-sm"
    aria-label="Completed"
  >
    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
  </span>
  <div class="flex items-start gap-4">
    {icon && <span class="text-3xl" role="img">{icon}</span>}
    <div class="flex-1 min-w-0">
      <h3 class="text-lg font-semibold text-surface-900 group-hover:text-primary-600 dark:text-white dark:group-hover:text-primary-400 transition-colors">
        {title}
      </h3>
      <p class="mt-1 text-sm text-surface-600 dark:text-surface-400 line-clamp-2">{description}</p>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        {difficulty && (
          <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ${difficultyColors[difficulty]}`}>
            {difficulty.charAt(0).toUpperCase() + difficulty.slice(1)}
          </span>
        )}
        {duration && (
          <span class="inline-flex items-center gap-1 text-xs text-surface-500 dark:text-surface-400">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {duration}
          </span>
        )}
        {tags.map(tag => (
          <span class="inline-flex items-center rounded-full bg-primary-50 px-2 py-0.5 text-xs font-medium text-primary-700 dark:bg-primary-900/20 dark:text-primary-300">
            {tag}
          </span>
        ))}
      </div>
    </div>
    <svg class="h-5 w-5 flex-shrink-0 text-surface-400 group-hover:text-primary-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  </div>
</a>

<script is:inline>
(function () {
  var cards = document.querySelectorAll('[data-course-id]');
  cards.forEach(function (card) {
    var id = card.getAttribute('data-course-id');
    if (localStorage.getItem('copilot-learn-progress:' + id) === 'true') {
      var badge = card.querySelector('.course-complete-badge');
      if (badge) badge.classList.replace('hidden', 'inline-flex');
    }
  });
})();
</script>
