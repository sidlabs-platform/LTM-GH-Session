---
interface Props {
  courseId: string;
}

const { courseId } = Astro.props;
const storageKey = `copilot-learn-progress:${courseId}`;
---

<div
  id="progress-tracker"
  class="mt-10 rounded-xl border border-surface-200 bg-surface-50 p-5 dark:border-surface-700 dark:bg-surface-800/50"
  data-storage-key={storageKey}
>
  <!-- Not completed state -->
  <div id="progress-incomplete" class="flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-surface-700 dark:text-surface-200">Finished this course?</p>
      <p class="text-xs text-surface-500 dark:text-surface-400">Track your progress locally</p>
    </div>
    <button
      id="mark-complete-btn"
      type="button"
      class="inline-flex items-center gap-2 rounded-lg bg-primary-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:focus:ring-offset-surface-900"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      Mark as Complete
    </button>
  </div>

  <!-- Completed state (hidden by default) -->
  <div id="progress-complete" class="hidden flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-green-100 dark:bg-green-900/30">
        <svg class="h-5 w-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </span>
      <span class="text-sm font-medium text-green-700 dark:text-green-400">Completed ✓</span>
    </div>
    <button
      id="unmark-complete-btn"
      type="button"
      class="text-xs text-surface-400 underline transition-colors hover:text-surface-600 dark:hover:text-surface-300"
    >
      Undo
    </button>
  </div>
</div>

<script is:inline>
(function () {
  const tracker = document.getElementById('progress-tracker');
  if (!tracker) return;

  const key = tracker.dataset.storageKey;
  const incompleteEl = document.getElementById('progress-incomplete');
  const completeEl = document.getElementById('progress-complete');
  const markBtn = document.getElementById('mark-complete-btn');
  const unmarkBtn = document.getElementById('unmark-complete-btn');

  function update() {
    const done = localStorage.getItem(key) === 'true';
    incompleteEl.classList.toggle('hidden', done);
    completeEl.classList.toggle('hidden', !done);
  }

  markBtn.addEventListener('click', function () {
    localStorage.setItem(key, 'true');
    update();
  });

  unmarkBtn.addEventListener('click', function () {
    localStorage.removeItem(key);
    update();
  });

  update();
})();
</script>
